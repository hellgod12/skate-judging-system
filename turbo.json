{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NEXT_PRIVATE_SKIP_WORKSPACE_CHECK"
  ],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    }
  }
}
